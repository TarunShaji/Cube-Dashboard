# MongoDB connection (supports Local, Atlas, and AWS DocumentDB)
# For local:      mongodb://localhost:27017
# For Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# For DocumentDB: mongodb://<user>:<password>@<endpoint>:27017/dashboard?tls=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false&authMechanism=SCRAM-SHA-1&authSource=admin
MONGO_URL=mongodb://YOUR_USER:YOUR_PASSWORD@YOUR_ENDPOINT:27017/dashboard

# Required for AWS DocumentDB SSL connections
# MONGO_CA_PATH=./rds-combined-ca-bundle.pem

DB_NAME=dashboard

# App configuration
# Set to your production URL when deployed
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
# Comma-separated allowed browser origins for API CORS.
# Example:
# CORS_ORIGINS=https://cube-dashboard-ashen.vercel.app,https://cube-dashboard-ashen-git-feature.vercel.app
CORS_ORIGINS=https://your-app.vercel.app

# Security — generate a long random string for production
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_jwt_secret_here
