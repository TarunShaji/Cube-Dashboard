# 🟢 Database
# Local:      mongodb://localhost:27017
# Atlas:      mongodb+srv://<user>:<password>@<cluster>.mongodb.net
# DocumentDB: See MIGRATION.md for specific AWS parameters
MONGO_URL=mongodb://localhost:27017
MONGO_CA_PATH=./rds-combined-ca-bundle.pem
DB_NAME=dashboard

# 🌐 App Configuration
# Replace with your actual domain (e.g., https://dashboard.cubehq.ai)
NEXT_PUBLIC_BASE_URL=https://dashboard.cubehq.ai
CORS_ORIGINS=https://dashboard.cubehq.ai

# 🔐 Security
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
